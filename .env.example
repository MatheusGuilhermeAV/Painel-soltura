# Copie para .env e preencha. Nunca commite o arquivo .env.
FLASK_DEBUG=0

# MySQL — base soltura_tempo_real (rede interna / VPN)
MYSQL_HOST=192.168.138.12
MYSQL_PORT=3306
MYSQL_USER=MANUTENCAO
MYSQL_PASSWORD=
MYSQL_DATABASE=soltura_tempo_real
MYSQL_TABLE=viagenspercursobusdor

# Nomes das colunas na tabela viagenspercursobusdor (confirmar com DESCRIBE)
COL_PREFIXO=vehicle_code
COL_PLACA=placa
COL_LAT=latitude
COL_LON=longitude
COL_HORA_POSICAO=date
COL_LINHA=linha
COL_SENTIDO=sentido
COL_MOTORISTA=motorista
COL_VIAGEM=viagem
COL_VELOCIDADE=velocidade
COL_IGNICAO=ignicao

# Regras (minutos)
STALE_ATTENTION_MINUTES=20
STALE_CRITICAL_MINUTES=60
STOPPED_ATTENTION_MINUTES=15
STOPPED_SPEED_KMH=3

# Garagem (círculo aproximado) — ajuste coordenadas reais
GARAGE_LAT=
GARAGE_LON=
GARAGE_RADIUS_METERS=200

# Fuso operacional (MySQL naive + exibição na UI). Manaus AM = America/Manaus. Vazio = UTC.
DATA_EVENT_TIMEZONE=America/Manaus

# --- API Sonda (HTTP; urllib) ---
# Para a frota usar Sonda como fonte principal, precisa TUDO abaixo:
#   is_configured() = SONDA_API_BASE preenchido E SONDA_FLEET_PATH preenchido
#   + chamada HTTP sem erro
#   + pelo menos 1 veículo normalizado (código + dados) em fetch_fleet_snapshot
# Caso contrário: tempo.fonte_principal_frota = "mysql" (dados parados na base).
SONDA_API_BASE=
# Credencial (use um dos dois; o projeto lê os dois nomes)
SONDA_API_TOKEN=
# SONDA_API_KEY=
# bearer (Authorization: Bearer …) ou apikey (header SONDA_API_KEY_HEADER)
SONDA_AUTH_TYPE=bearer
SONDA_API_KEY_HEADER=X-API-Key
# Caminho relativo à base, OBRIGATÓRIO junto com SONDA_API_BASE (ex.: api/v1/frota)
SONDA_FLEET_PATH=
# Opcional: GET por veículo, use {prefixo} (ex.: api/v1/veiculos/{prefixo})
SONDA_VEHICLE_PATH_TEMPLATE=
# Se o JSON for objeto, chave até a lista (ex.: data.items). Vazio = raiz é array JSON.
SONDA_RESPONSE_ROOT_KEY=
SONDA_TIMEOUT_SECONDS=15
# 0 = ignorar erro de certificado SSL (somente rede interna de confiança)
SONDA_VERIFY_SSL=1

# Nomes dos campos no JSON de cada veículo (ajustar à matriz real da Sonda)
SONDA_FIELD_VEHICLE_CODE=vehicle_code
SONDA_FIELD_DRIVER_NAME=driver_name
SONDA_FIELD_DRIVER_ID=driver_id
SONDA_FIELD_TRIP_ID=trip_id
SONDA_FIELD_TRIP_STATUS=trip_status
SONDA_FIELD_SPEED=speed
SONDA_FIELD_IGNITION=ignition
SONDA_FIELD_LINE=route
SONDA_FIELD_DIRECTION=direction
SONDA_FIELD_EVENT_TIME=gps_time
SONDA_FIELD_LAT=latitude
SONDA_FIELD_LON=longitude

# Valores de trip_status que significam viagem ativa (maiúsculas ignoradas)
SONDA_TRIP_ACTIVE_VALUES=OPEN,ATIVA,EM_VIAGEM,IN_PROGRESS,ACTIVE,1
